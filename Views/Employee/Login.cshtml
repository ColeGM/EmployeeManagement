@{ Layout = null; }
<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { height: 100vh; display: flex; align-items: center; background: #121212; }
        .login-card { width: 100%; max-width: 400px; padding: 2rem; background: #1e1e1e; border-radius: 15px; border: 1px solid #333; }
    </style>
</head>
<body>
    <div class="container d-flex justify-content-center">
        <div class="login-card shadow-lg text-center">
            <h3 class="fw-bold mb-4 text-white">MOLA Access</h3>
            @if(ViewBag.Error != null){ <div class="alert alert-danger">@ViewBag.Error</div> }
            <form asp-action="Login" method="post">
                <input name="user" class="form-control mb-3" placeholder="Username" required>
                <input name="pass" type="password" class="form-control mb-4" placeholder="Password" required>
                <button type="submit" class="btn btn-primary w-100 py-2 fw-bold">Enter System</button>
            </form>
        </div>
    </div>
</body>
</html>
