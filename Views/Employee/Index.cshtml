@model IEnumerable<EmployeeManagement.Models.Employee>
@using System.Globalization
@{ var us = new CultureInfo("en-US"); }

<div class="container py-4">
    <div class="card border-0 shadow-sm mb-4 bg-body-tertiary">
        <div class="card-body">
            <h5 class="fw-bold"><i class="bi bi-person-plus-fill me-2"></i>Hire New Talent</h5>
            <form asp-action="Hire" method="post" class="row g-2">
                <div class="col-md-3"><input name="Name" class="form-control form-control-sm" placeholder="Full Name" required></div>
                <div class="col-md-2">
                    <select name="Department" class="form-select form-select-sm">
                        <option>IT</option><option>HR</option><option>Sales</option>
                    </select>
                </div>
                <div class="col-md-3"><input name="Position" class="form-control form-control-sm" placeholder="Title (e.g. Developer)"></div>
                <div class="col-md-2"><input name="Salary" type="number" class="form-control form-control-sm" placeholder="Salary"></div>
                <div class="col-md-2"><button type="submit" class="btn btn-primary btn-sm w-100">Add to Ledger</button></div>
            </form>
        </div>
    </div>

    <div class="neon-border-wrapper">
        <div class="inner-content p-1">
            <table class="table align-middle mb-0">
                <thead>
                    <tr><th>Staff</th><th>Department</th><th>Salary</th><th class="text-end">Management Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in Model) {
                        <tr>
                            <td>
                                <div class="fw-bold">@item.Name</div>
                                <div class="small text-muted">@item.Position</div>
                            </td>
                            <td><span class="badge rounded-pill bg-dark">@item.Department</span></td>
                            <td class="fw-bold text-success">@item.Salary.ToString("C0", us)</td>
                            <td class="text-end">
                                <div class="d-flex justify-content-end gap-2">
                                    <form asp-action="Promote" asp-route-id="@item.EmployeeID" method="post">
                                        <button title="Promote" class="btn btn-sm btn-outline-success border-0"><i class="bi bi-graph-up-arrow"></i></button>
                                    </form>
                                    <form asp-action="Delete" asp-route-id="@item.EmployeeID" method="post" onsubmit="return confirm('Confirm Termination?');">
                                        <button title="Terminate" class="btn btn-sm btn-outline-danger border-0"><i class="bi bi-fire"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
